---
/**
 * Botão de WhatsApp (deep link wa.me) com a mensagem pré-preenchida da LP.
 * Dispara o evento `Contact` do Meta Pixel no clique.
 * Reutiliza o estilo do Botao do design system.
 */
import Botao from './Botao.astro';
import { site } from '../data/site';

interface Props {
  mensagem: string;
  texto?: string;
  variant?: 'primary' | 'onDark' | 'ghost';
  size?: 'sm' | 'lg';
  block?: boolean;
}
const { mensagem, texto = 'Falar no WhatsApp', variant = 'primary', size = 'lg', block = false } = Astro.props;
const href = `https://wa.me/${site.whatsappNumero}?text=${encodeURIComponent(mensagem)}`;
---
<Botao
  href={href}
  variant={variant}
  size={size}
  block={block}
  target="_blank"
  rel="noopener"
  class="js-whats"
>
  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path d="M12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.86 9.86 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm5.8 14.16c-.24.68-1.42 1.32-1.95 1.36-.5.04-.97.27-3.27-.68-2.76-1.14-4.5-3.99-4.64-4.18-.13-.18-1.11-1.48-1.11-2.82 0-1.34.7-2 .95-2.27.24-.27.53-.34.71-.34.18 0 .35 0 .51.01.16.01.39-.06.6.46.24.55.81 1.9.88 2.04.07.14.12.3.02.48-.09.18-.14.3-.27.46-.13.16-.28.36-.4.48-.13.13-.27.28-.12.54.16.27.7 1.15 1.5 1.86 1.03.92 1.9 1.2 2.17 1.34.27.14.43.12.59-.07.16-.18.68-.79.86-1.06.18-.27.36-.23.6-.14.24.09 1.55.73 1.81.86.27.13.45.2.51.31.07.11.07.64-.17 1.32Z"/>
  </svg>
  {texto}
</Botao>

<script>
  import { trackContact } from '../lib/tracking';
  document.querySelectorAll('.js-whats').forEach((el) =>
    el.addEventListener('click', () => trackContact()),
  );
</script>
