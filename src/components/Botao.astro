---
/**
 * Botão do design system (bronze).
 * Variantes: primary (fill bronze) · onDark (sobre fundo escuro) · ghost (contorno).
 * Tamanhos: sm (36px) · lg (52px).
 * Renderiza <a> quando há `href`, senão <button>.
 */
interface Props {
  href?: string;
  variant?: 'primary' | 'onDark' | 'ghost';
  size?: 'sm' | 'lg';
  type?: 'button' | 'submit';
  block?: boolean;
  target?: string;
  rel?: string;
  class?: string;
}
const {
  href,
  variant = 'primary',
  size = 'lg',
  type = 'button',
  block = false,
  target,
  rel,
  class: extra = '',
} = Astro.props;
const cls = `btn btn-${variant} btn-${size}${block ? ' btn-block' : ''}${extra ? ' ' + extra : ''}`;
const Tag = href ? 'a' : 'button';
---
<Tag
  class={cls}
  href={href}
  target={target}
  rel={rel}
  type={href ? undefined : type}
>
  <slot />
</Tag>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-family: var(--font-sans);
    font-weight: 600;
    border-radius: var(--radius-pill);
    border: 1px solid transparent;
    cursor: pointer;
    text-align: center;
    transition: background 220ms cubic-bezier(0.4, 0, 0.2, 1),
      color 220ms, border-color 220ms, transform 140ms;
  }
  .btn:active { transform: scale(0.97); }
  .btn-block { width: 100%; }

  .btn-sm { height: 36px; padding: 0 18px; font-size: 0.8rem; }
  .btn-lg { height: 52px; padding: 0 28px; font-size: 0.95rem; }

  /* Primary — fill bronze, texto cream, escurece no hover */
  .btn-primary {
    background: var(--bronze-600);
    color: var(--cream-100);
  }
  .btn-primary:hover { background: var(--bronze-700); }

  /* onDark — sobre fundo escuro: texto cream, borda suave, wash bronze no hover */
  .btn-onDark {
    background: rgba(237, 224, 200, 0.06);
    color: var(--cream-100);
    border-color: rgba(237, 224, 200, 0.25);
  }
  .btn-onDark:hover {
    background: var(--bronze-600);
    border-color: var(--bronze-600);
  }

  /* Ghost — contorno suave, wash bronze no hover */
  .btn-ghost {
    background: transparent;
    color: var(--cream-100);
    border-color: rgba(237, 224, 200, 0.25);
  }
  .btn-ghost:hover { background: rgba(117, 77, 42, 0.25); }
</style>
